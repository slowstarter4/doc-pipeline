# 복사해서 .env 로 이름 바꾸고 값을 채우세요
OPENROUTER_API_KEY=your-key-here

# (선택) 모델 바꾸고 싶을 때만
# PIPELINE_MODEL=~anthropic/claude-sonnet-latest

# (선택) 백엔드 구현 스택 선택: fastapi(기본) | spring | express | typescript
# 네 스택 모두 DB 영속성 있음. 파이프라인 내장 자동 실행 검증(스모크·영속성)은
# fastapi 전용이고, 나머지 3스택은 backend-runtime-verifier 에이전트로 검증한다
# BACKEND_TARGET=fastapi

# (선택) 프론트엔드 구현 스택 선택: vanilla(기본, 빌드 없는 index.html) | react(Vite)
# FRONTEND_TARGET=react

# (선택) DB 방언: sqlite(기본, 파일 DB) | postgres
# postgres는 먼저 `docker compose up -d`로 컨테이너를 띄워야 한다(호스트 포트 55432).
# 파이프라인은 도커를 자동 기동하지 않고 DATABASE_URL로 붙기만 한다
# DB_TARGET=sqlite
