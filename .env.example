# 복사해서 .env 로 이름 바꾸고 값을 채우세요
OPENROUTER_API_KEY=your-key-here

# (선택) 모델 바꾸고 싶을 때만
# PIPELINE_MODEL=~anthropic/claude-sonnet-latest

# (선택) 백엔드 구현 스택 선택: fastapi(기본) | spring | express | typescript
# 자동 실행 검증(스모크·영속성)과 sqlite 규칙은 fastapi에만 적용된다
# BACKEND_TARGET=fastapi

# (선택) 프론트엔드 구현 스택 선택: vanilla(기본, 빌드 없는 index.html) | react(Vite)
# FRONTEND_TARGET=react
